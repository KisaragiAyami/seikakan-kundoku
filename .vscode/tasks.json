{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Watch Fonts",
            "type": "shell",
            "command": "node",
            "args": ["js/watch-fonts.js"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "isBackground": true,
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Watch Pages",
            "type": "shell",
            "command": "node",
            "args": ["watch-pages.js"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "isBackground": true,
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}